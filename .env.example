# Backend dependencies (from repo root):  python -m pip install -r requirements.txt
# Save requirements.txt as UTF-8 if you edit it (Notepad "UTF-8"; avoid UTF-16 or pip errors).

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# Frontend production API (also set in Vercel/hosting as VITE_API_URL when building)
# VITE_API_URL=https://facematch-test.onrender.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
